# Image version to run (pin a release tag in production, e.g. v0.1.0)
AGENTGRAM_VERSION=latest

# Public host:port the API advertises (used for OAuth metadata / MCP)
SERVER_HOST=localhost:8080

# Logging
LOG_LEVEL=info

# PostgreSQL — change the password before exposing anything
POSTGRES_USER=agentgram
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agentgram
POSTGRES_SSLMODE=disable

# Redis (leave empty for no password in this local example)
REDIS_PASSWORD=

# --- Auth (only needed if you enable Keycloak in config.yaml) ---
# KEYCLOAK_ISSUER=https://keycloak.example.com/realms/master
# OIDC_CLIENT_ID=agentgram
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://agentgram.example.com/auth/callback
# OIDC_POST_LOGOUT_URI=https://agentgram.example.com/login
