# Server
PORT=8080
CONFIG_PATH=./configs/config.yaml

# Auth
ADMIN_GROUP=/google-workspace/admins@example.com

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Keycloak / OIDC
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/master
OIDC_CLIENT_ID=ui-agents
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_POST_LOGOUT_URI=http://localhost:3000/login

# MCP Server Config (Opcional, hereda de Keycloak si no se definen)
MCP_SERVER_ISSUER=https://keycloak.example.com/realms/mcp-servers
MCP_SERVER_CLIENT_ID=agentgram-mcp
MCP_SERVER_DCR_MODE=static # "static" | "upstream" | "disabled"

# LLM - Summarizer (generates session titles)
LLM_SUMMARIZER_PROVIDER=anthropic
LLM_SUMMARIZER_MODEL=claude-haiku-4-5-20251001
LLM_SUMMARIZER_API_KEY=

# LLM - File Processor
LLM_FILE_PROCESSOR_PROVIDER=anthropic
LLM_FILE_PROCESSOR_MODEL=claude-sonnet-4-20250514
LLM_FILE_PROCESSOR_API_KEY=

# LLM - Chat Model
ANTHROPIC_API_KEY=
LLM_MODEL_ANTHROPIC=claude-sonnet-4-20250514

# Agent Endpoints (set per environment, referenced from config.yaml via ${ENV:VAR})
# Define one block per agent you register. Examples:

# Custom REST/SSE agent
EXAMPLE_AGENT_ENDPOINT=http://localhost:9000/chat
EXAMPLE_AGENT_HEALTH_URL=http://localhost:9000/health

# A2A (Agent-to-Agent, JSON-RPC) agent
KUBE_AGENT_ENDPOINT=http://localhost:9001/a2a/agent
KUBE_AGENT_HEALTH_URL=http://localhost:9001/health

# A2A agent advertising an agent card
METRICS_AGENT_ENDPOINT=http://localhost:9002/a2a/invoke
METRICS_AGENT_HEALTH_URL=http://localhost:9002/.well-known/agent-card.json
